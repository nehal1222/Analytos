:{$PORT} {
	# Dashboard API -- backend routes are already defined with the /api
	# prefix baked in (main.py), so forward as-is, no path rewrite.
	handle /api/* {
		reverse_proxy 127.0.0.1:8000
	}

	# Each MCP server listens on its own internal port at the FastMCP
	# default path (/mcp). Named matchers (not handle_path -- that
	# directive only accepts a single pattern, not several space-
	# separated ones) match either the bare role path or anything under
	# it; the rewrite then replaces the whole path with exactly what
	# each server expects, so no prefix-stripping is needed either.
	@content_agent path /mcp/content-agent /mcp/content-agent/*
	handle @content_agent {
		rewrite * /mcp
		reverse_proxy 127.0.0.1:9001
	}

	@gtm_agent path /mcp/gtm-agent /mcp/gtm-agent/*
	handle @gtm_agent {
		rewrite * /mcp
		reverse_proxy 127.0.0.1:9002
	}

	# Dashboard UI (built by the frontend-builder Docker stage). try_files
	# falls back to index.html for any path that isn't a real static asset
	# so client-side routing (React state, not URL-based here, but keeps
	# this correct if that changes) doesn't 404 on refresh.
	handle {
		root * /app/console/frontend/dist
		try_files {path} /index.html
		file_server
	}
}
